ios/src/musicgen/_engine/
ios/build/
ios/dist/
ios/.venv/

# --- Python ---
venv/
venv_new/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# --- OS / editor cruft ---
.DS_Store
*.swp
log/

# Local Claude Code settings (personal)
.claude/settings.local.json

