# --- Generated audio/MIDI output (regenerable) ---
output/
metadata/

# --- Large binary assets (not tracked; keep locally / download separately) ---
SoundFonts/
ios/src/musicgen/resources/*.sf2
ios/src/musicgen/resources/*.dls
# ...except the tiny (~300 KB) GM font bundled as the playback default.
!ios/src/musicgen/resources/default_gm.sf2

# --- iOS app (BeeWare/Briefcase) ---
# Vendored engine (single source of truth is the repo root; see ios/README.md)
ios/src/musicgen/_engine/
ios/build/
ios/dist/
ios/.venv/

# --- Web app (PWA / Pyodide) build artifacts ---
# Single source of truth is the repo root; these are regenerated by
# web/tools/*.py (see web/README.md) and by the Pages deploy workflow.
web/engine.zip
web/pyodide/
web/node_modules/

# --- Python ---
venv/
venv_new/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# --- OS / editor cruft ---
.DS_Store
*.swp
log/

# Local Claude Code settings (personal)
.claude/settings.local.json

# Lead-sheet source PDFs (inputs; often large/copyrighted/cloud-synced)
songs/*.pdf
