# --- Generated audio/MIDI output (regenerable) ---
output/
metadata/

# --- Large binary assets (not tracked; keep locally / download separately) ---
SoundFonts/

# --- Build output (generated; regenerable from source) ---
webapp/frontend/dist/
webapp/chords-frontend/dist/
node_modules/
webapp/backend/.deps-installed

# --- Packaged / exported artifacts (regenerable; often huge) ---
music-generator.zip
Music Generator.app/

# --- Python ---
venv/
venv_new/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.coverage
htmlcov/

# --- OS / editor cruft ---
.DS_Store
*.swp
log/

# Local Claude Code settings (personal)
.claude/settings.local.json

# Lead-sheet source PDFs (inputs; often large/copyrighted/cloud-synced)
songs/*.pdf

# Private provenance / research material (kept local, never committed)
docs/sources/

# MkDocs local build output (docs are published by pages.yml)
_site_docs/
_public/

# Preset/progression fixtures leaked by an interrupted test run (the API
# tests clean up after themselves via try/finally, but a killed run can't)
presets/**/test_*.json

# Progression library database (runtime data; legacy *.json seeds migrate in)
presets/**/*.db
presets/**/*.db-wal
presets/**/*.db-shm
