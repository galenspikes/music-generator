#!/bin/zsh
# Thin shim: the old 497-line wrapper was ported to Python (render.py).
# Kept so existing `./play_music ...` commands still work unchanged.
set -e
SCRIPT_SRC="${0:A}"
SCRIPT_DIR="${SCRIPT_SRC:h}"
PY="$SCRIPT_DIR/venv/bin/python3"
[[ -x "$PY" ]] || PY="$(/usr/bin/which python3)"
exec "$PY" "$SCRIPT_DIR/render.py" "$@"
