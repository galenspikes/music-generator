#!/bin/zsh
set -euo pipefail
setopt NULL_GLOB

usage() {
  cat <<'EOF'
Usage: play_music [options] [generator args...]

Wrapper controls:
  -h, --help               Show this help and exit
      --sf2 PATH           Forwarded to generator and used for FluidSynth render
      --fx NAME            Apply FluidSynth FX preset (chorus-super | lush | dry | none)
      --chorus-super       Backward-compatible alias for --fx chorus-super
      --normalize          Normalize audio loudness via ffmpeg loudnorm
      --boost-db N         Apply ffmpeg volume boost in dB
      --boost-normalize N  Normalize, then apply additional boost in dB
      --no-play            Skip afplay playback
      --save-wav           Render and keep a WAV alongside the MIDI output
      --output-dir DIR     Directory for rendered WAV output (default: audio)
      --keep-temporary     Copy instead of move rendered WAV, preserving temp files

All unrecognized flags/args are forwarded to music_generator.py.
EOF
}

die_usage() {
  print -u2 -- "❌ ${1:-Invalid usage.}"
  usage
  exit 64
}

run_with_spinner() {
  local label="$1"
  shift
  echo "$label"
  "$@"
}

# --- resolve symlink to real path ---
resolve_link() {
  local p="$1" target
  p="${p:A}"
  while [[ -L "$p" ]]; do
    target="$(readlink "$p")"
    [[ "$target" = /* ]] || target="${p:h}/$target"
    p="${target:A}"
  done
  print -- "$p"
}

SCRIPT_SRC="$(resolve_link "$0")"
SCRIPT_DIR="${SCRIPT_SRC:h}"
cd "$SCRIPT_DIR"

PYTHON="$SCRIPT_DIR/venv/bin/python3"
GEN="$SCRIPT_DIR/music_generator.py"

# Fallback Python if venv missing
if [[ ! -x "$PYTHON" ]]; then
  if /usr/bin/which python3 >/dev/null 2>&1; then
    PYTHON="$(/usr/bin/which python3)"
  else
    echo "❌ No python found (expected venv at $SCRIPT_DIR/venv)."
    exit 1
  fi
fi

CONFIG_PATH="$SCRIPT_DIR/config.json"
typeset -a CONFIG_WRAPPER_ARGS
CONFIG_WRAPPER_ARGS=()
typeset -a CONFIG_FORWARD_ARGS
CONFIG_FORWARD_ARGS=()

if [[ -f "$CONFIG_PATH" ]]; then
  config_output="$($PYTHON -c 'import json, os, sys
from pathlib import Path

def flatten(values):
    if isinstance(values, str):
        return [values]
    if isinstance(values, (int, float)):
        return [str(values)]
    if isinstance(values, (list, tuple)):
        out = []
        for item in values:
            out.extend(flatten(item))
        return out
    if values is None:
        return []
    return [str(values)]

def emit(prefix, tokens):
    for token in tokens:
        if not token:
            continue
        print(f"{prefix}={token}")

path = Path(sys.argv[1])
try:
    data = json.loads(path.read_text(encoding="utf-8"))
except Exception as exc:
    print(f"wrapper=__CONFIG_ERROR__:{exc}", file=sys.stderr)
    sys.exit(0)

default_sf2 = data.get("default_sf2")
if default_sf2:
    sf2_path = os.path.expanduser(str(default_sf2))
    emit("wrapper", ["--sf2", sf2_path])

wrapper_defaults = data.get("default_wrapper_flags") or []
flat_wrapper = []
for entry in wrapper_defaults:
    flat_wrapper.extend(flatten(entry))
emit("wrapper", [os.path.expanduser(token) for token in flat_wrapper])

forward_defaults = data.get("default_generator_flags") or []
flat_forward = []
for entry in forward_defaults:
    flat_forward.extend(flatten(entry))
emit("forward", [os.path.expanduser(token) for token in flat_forward])
' "$CONFIG_PATH")"

  if [[ -n "$config_output" ]]; then
    while IFS=$'\n' read -r line; do
      case "$line" in
        wrapper=*)
          CONFIG_WRAPPER_ARGS+=("${line#wrapper=}")
          ;;
        forward=*)
          CONFIG_FORWARD_ARGS+=("${line#forward=}")
          ;;
      esac
    done <<< "$config_output"
  fi

  if (( ${#CONFIG_WRAPPER_ARGS[@]} )); then
    set -- "${CONFIG_WRAPPER_ARGS[@]}" "$@"
  fi
fi

# -------- Wrapper-only flags (not forwarded to generator) --------
SF2_ARG=""
FX_PRESET="dry"
DO_NORMALIZE=0
BOOST_DB=""
BOOST_AFTER_NORM=""
NO_PLAY=0
OUTPUT_DIR="audio"
KEEP_TEMPORARY=0
SAVE_WAV=0

# Forward all other args to the generator
FORWARD_ARGS=("${CONFIG_FORWARD_ARGS[@]}")

while (( $# )); do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --sf2)
      (( $# >= 2 )) || die_usage "--sf2 requires a path."
      SF2_ARG="$2"
      FORWARD_ARGS+=(--sf2 "$SF2_ARG")
      shift 2
      continue
      ;;
    --fx)
      (( $# >= 2 )) || die_usage "--fx requires a preset name."
      FX_PRESET="$2"
      shift 2
      continue
      ;;
    --chorus-super)
      FX_PRESET="chorus-super"
      shift
      continue
      ;;
    --normalize)
      DO_NORMALIZE=1
      shift
      continue
      ;;
    --boost-db)
      (( $# >= 2 )) || die_usage "--boost-db requires a numeric value."
      BOOST_DB="$2"
      shift 2
      continue
      ;;
    --boost-normalize)
      (( $# >= 2 )) || die_usage "--boost-normalize requires a numeric value."
      BOOST_AFTER_NORM="$2"
      shift 2
      continue
      ;;
    --no-play)
      NO_PLAY=1
      shift
      continue
      ;;
    --output-dir)
      (( $# >= 2 )) || die_usage "--output-dir requires a directory path."
      OUTPUT_DIR="$2"
      shift 2
      continue
      ;;
    --keep-temporary)
      KEEP_TEMPORARY=1
      shift
      continue
      ;;
    --save-wav)
      SAVE_WAV=1
      shift
      continue
      ;;
    --)
      shift
      FORWARD_ARGS+=("$@")
      break
      ;;
    *)
      FORWARD_ARGS+=("$1")
      shift
      continue
      ;;
  esac
done

if [[ ! -f "$GEN" ]]; then
  echo "❌ music_generator.py not found at $GEN"
  exit 1
fi

# Find fluidsynth in common locations
FLUIDSYNTH_CMD=""
for path in "/opt/homebrew/bin/fluidsynth" "/usr/local/bin/fluidsynth" "$(/usr/bin/which fluidsynth 2>/dev/null)"; do
  if [[ -x "$path" ]]; then
    FLUIDSYNTH_CMD="$path"
    break
  fi
done

if [[ -n "$SF2_ARG" ]] && [[ -z "$FLUIDSYNTH_CMD" ]]; then
  echo "❌ --sf2 provided but fluidsynth is not available."
  exit 1
fi

if (( DO_NORMALIZE )) || [[ -n "$BOOST_DB" || -n "$BOOST_AFTER_NORM" ]]; then
  if ! /usr/bin/which ffmpeg >/dev/null 2>&1; then
    echo "❌ ffmpeg is required for normalize/boost options."
    exit 1
  fi
fi

# Don't skip playback just because afplay is missing - FluidSynth can handle it
# if (( ! NO_PLAY )) && ! command -v afplay >/dev/null 2>&1; then
#   echo "ℹ️  afplay not found; skipping playback."
#   NO_PLAY=1
# fi

/bin/mkdir -p "$OUTPUT_DIR" output/metadata output/library

echo "🐍 Using Python: $PYTHON"
# Capture the output from the generator to get the specific MIDI filename
generator_output=$("$PYTHON" "$GEN" "${FORWARD_ARGS[@]}" 2>&1)
echo "$generator_output"

# Extract the MIDI filename from the generator output
# The generator outputs: "Wrote /path/to/filename.mid"
latest_mid=$(echo "$generator_output" | /usr/bin/grep "Wrote " | /usr/bin/sed 's/.*Wrote //')
if [[ -z "$latest_mid" ]]; then
  echo "ℹ️ No MIDI found. Did the generator fail?"
  exit 1
fi

typeset -a FS_OPTS
FS_OPTS=()
if [[ -n "$SF2_ARG" ]]; then
  case "${FX_PRESET:-}" in
    ''|none)
      ;;
    chorus-super)
      FS_OPTS=(
        -o synth.chorus.active=1
        -o synth.chorus.nr=5
        -o synth.chorus.level=8
        -o synth.chorus.depth=8
        -o synth.chorus.speed=0.30
      )
      ;;
    lush)
      FS_OPTS=(
        -o synth.chorus.active=1
        -o synth.chorus.level=7
        -o synth.chorus.depth=10
        -o synth.chorus.speed=0.40
        -o synth.reverb.active=1
        -o synth.reverb.level=0.8
        -o synth.reverb.room-size=0.7
      )
      ;;
    dry)
      FS_OPTS=(
        -o synth.chorus.active=0
        -o synth.reverb.active=0
      )
      ;;
    *)
      echo "❌ Unknown FX preset '${FX_PRESET}'. Available: none, chorus-super, lush, dry."
      exit 64
      ;;
  esac

  if (( ${#FS_OPTS[@]} )); then
    echo "✨ FluidSynth FX preset '${FX_PRESET:-none}': ${FS_OPTS[@]}"
  fi
fi

slug=$(/usr/bin/basename "$(/usr/bin/dirname "$latest_mid")")
base_name=$(/usr/bin/basename "$latest_mid" .mid)
audio_slug_dir="$OUTPUT_DIR/$slug"
metadata_slug_dir="metadata/$slug"
/bin/mkdir -p "$audio_slug_dir" "$metadata_slug_dir"

candidate_wav="$audio_slug_dir/${base_name}.wav"
final_wav=""
candidate_record=""
typeset -a _prev_paths
_prev_paths=()

if (( SAVE_WAV )); then
  if [[ -z "$SF2_ARG" ]]; then
    echo "ℹ️ --save-wav requested but no --sf2 provided; skipping WAV render."
    SAVE_WAV=0
  else
    if [[ -z "$FLUIDSYNTH_CMD" ]]; then
      echo "❌ FluidSynth is required to render WAV output."
      exit 1
    fi

    typeset -a render_cmd
    render_cmd=("$FLUIDSYNTH_CMD" -q -ni)
    if (( ${#FS_OPTS[@]} )); then
      render_cmd+=("${FS_OPTS[@]}")
    fi
    render_cmd+=(-F "$candidate_wav" "$SF2_ARG" "$latest_mid")
    echo "➡️  ${render_cmd[@]}"
    run_with_spinner "Rendering WAV -> $candidate_wav" "${render_cmd[@]}"

    current_path="$candidate_wav"

    if (( DO_NORMALIZE )) || [[ -n "$BOOST_DB" || -n "$BOOST_AFTER_NORM" ]]; then
      norm_needed=$(( DO_NORMALIZE ))
      [[ -n "$BOOST_AFTER_NORM" ]] && norm_needed=1

      if (( norm_needed )); then
        norm_path="${current_path%.wav}_norm.wav"
        typeset -a norm_cmd
        norm_cmd=(ffmpeg -y -hide_banner -loglevel error -i "$current_path" -af "loudnorm=I=-14:TP=-1.0:LRA=11" "$norm_path")
        run_with_spinner "Normalizing audio" "${norm_cmd[@]}"
        _prev_paths+=("$current_path")
        current_path="$norm_path"
      fi

      if [[ -n "$BOOST_DB" ]]; then
        boost_path="${current_path%.wav}_+${BOOST_DB}dB.wav"
        typeset -a boost_cmd
        boost_cmd=(ffmpeg -y -hide_banner -loglevel error -i "$current_path" -af "volume=${BOOST_DB}dB" "$boost_path")
        run_with_spinner "Boosting audio by ${BOOST_DB} dB" "${boost_cmd[@]}"
        _prev_paths+=("$current_path")
        current_path="$boost_path"
      fi

      if [[ -n "$BOOST_AFTER_NORM" ]]; then
        combo_path="${current_path%.wav}_+${BOOST_AFTER_NORM}dB.wav"
        typeset -a combo_cmd
        combo_cmd=(ffmpeg -y -hide_banner -loglevel error -i "$current_path" -af "volume=${BOOST_AFTER_NORM}dB" "$combo_path")
        run_with_spinner "Boosting post-normalize by ${BOOST_AFTER_NORM} dB" "${combo_cmd[@]}"
        _prev_paths+=("$current_path")
        current_path="$combo_path"
      fi
    fi

    final_wav="$current_path"
    candidate_record="$final_wav"

    if (( ! KEEP_TEMPORARY )); then
      for old_path in "${_prev_paths[@]}"; do
        [[ "$old_path" == "$final_wav" ]] && continue
        [[ -f "$old_path" ]] && rm -f "$old_path"
      done
    fi
  fi
else
  echo "ℹ️ Skipping WAV render (use --save-wav to enable)."
fi

timestamp_utc="$(/bin/date -u +'%Y-%m-%dT%H:%M:%SZ')"
metadata_path="$metadata_slug_dir/${base_name}.json"
final_wav_arg="$final_wav"
candidate_wav_arg="$candidate_record"

"$PYTHON" - "$metadata_path" "$timestamp_utc" "$PYTHON" "$GEN" "$final_wav_arg" "$latest_mid" "$candidate_wav_arg" "$SF2_ARG" "${FX_PRESET:-}" "$OUTPUT_DIR" "$BOOST_DB" "$BOOST_AFTER_NORM" "$DO_NORMALIZE" "$KEEP_TEMPORARY" "$NO_PLAY" "$SAVE_WAV" -- "${FORWARD_ARGS[@]}" <<'PY'
import json
import sys
from pathlib import Path

args = sys.argv[1:]
metadata_path = Path(args[0])
rest = args[1:]
if '--' in rest:
    split_index = rest.index('--')
    meta_args = rest[:split_index]
    generator_args = rest[split_index + 1 :]
else:
    meta_args = rest
    generator_args = []
(
    timestamp,
    python_exe,
    generator_script,
    final_wav,
    latest_mid,
    candidate_wav,
    sf2_arg,
    fx_preset,
    output_dir,
    boost_db,
    boost_after_norm,
    do_normalize,
    keep_temporary,
    no_play,
    save_wav,
) = meta_args
save_wav = bool(int(save_wav))
final_wav = final_wav or None
candidate_wav = candidate_wav or None
metadata = {
    "timestamp_utc": timestamp,
    "python": python_exe,
    "generator_script": generator_script,
    "generator_args": generator_args,
    "outputs": {
        "final_wav": final_wav,
        "latest_midi": latest_mid,
        "candidate_wav": candidate_wav,
        "wav_saved": save_wav,
    },
    "render": {
        "soundfont": sf2_arg or None,
        "fx_preset": fx_preset or "none",
        "output_dir": output_dir,
    },
    "post_processing": {
        "normalize": bool(int(do_normalize)),
        "boost_db": float(boost_db) if boost_db else None,
        "boost_after_normalize_db": float(boost_after_norm) if boost_after_norm else None,
    },
    "wrapper": {
        "keep_temporary": bool(int(keep_temporary)),
        "playback_disabled": bool(int(no_play)),
        "save_wav": save_wav,
    },
}
metadata_path.parent.mkdir(parents=True, exist_ok=True)
with metadata_path.open('w', encoding='utf-8') as handle:
    json.dump(metadata, handle, indent=2)
PY
echo "🧾 Metadata → $metadata_path"

if (( ! NO_PLAY )); then
  if (( SAVE_WAV )) && [[ -n "$final_wav" ]] && /usr/bin/which afplay >/dev/null 2>&1; then
    echo "▶️  Playing $final_wav"
    /usr/bin/afplay "$final_wav"
  elif [[ -n "$SF2_ARG" ]] && [[ -n "$FLUIDSYNTH_CMD" ]]; then
    typeset -a play_cmd
    play_cmd=("$FLUIDSYNTH_CMD" -q -i)
    if (( ${#FS_OPTS[@]} )); then
      play_cmd+=("${FS_OPTS[@]}")
    fi
    play_cmd+=("$SF2_ARG" "$latest_mid")
    echo "▶️  Playing via FluidSynth: ${play_cmd[@]}"
    "${play_cmd[@]}"
  else
    echo "ℹ️  No playback backend available; skipping."
  fi
fi
